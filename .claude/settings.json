{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:docs.microsoft.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:fluent2.microsoft.design)",
      "WebFetch(domain:react.fluentui.dev)",
      "WebFetch(domain:pnp.github.io)",
      "WebFetch(domain:developer.microsoft.com)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push --force-with-lease)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(git push --delete *)",
      "Bash(git push -d *)",
      "Bash(git push origin :*)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -fdx *)",
      "Bash(git checkout -- *)",
      "Bash(git restore -- *)",
      "Bash(git branch -D *)",
      "Bash(git tag -d *)",
      "Bash(git tag --delete *)",
      "Bash(git stash drop --all *)",
      "Bash(git stash drop --all)",
      "Bash(git stash clear)",
      "Bash(git filter-branch *)",
      "Bash(git update-ref -d *)",
      "Bash(git rebase -i *)",
      "Bash(git add -i *)",
      "Bash(git commit --no-verify *)",
      "Bash(git commit --no-verify)",
      "Bash(git commit -n *)",
      "Bash(git commit -n)",
      "Bash(git remote remove *)",
      "Bash(git remote rm *)",
      "Bash(npx husky)",
      "Bash(npx husky *)",
      "Bash(npm publish *)",
      "Bash(npm publish)",
      "Bash(gh pr merge *)",
      "Bash(gh release delete *)",
      "Bash(gh repo delete *)",
      "Bash(azd down *)",
      "Bash(azd down)",
      "Bash(az group delete *)",
      "Bash(az resource delete *)"
    ]
  }
}
